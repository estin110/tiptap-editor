{
  "name": "@het/tiptap-editor",
  "version": "0.1.0",
  "description": "Full-featured Vue 3 rich text editor component based on Tiptap",
  "type": "module",
  "license": "MIT",
  "author": "het",
  "keywords": [
    "vue",
    "tiptap",
    "rich-text-editor",
    "wysiwyg",
    "editor",
    "vue3"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "@tiptap/core": "^2.10.0",
    "@tiptap/pm": "^2.10.0",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@tiptap/extension-bubble-menu": "^2.27.2",
    "@tiptap/extension-color": "^2.10.0",
    "@tiptap/extension-highlight": "^2.10.0",
    "@tiptap/extension-image": "^2.10.0",
    "@tiptap/extension-link": "^2.10.0",
    "@tiptap/extension-mention": "^2.10.0",
    "@tiptap/extension-placeholder": "^2.10.0",
    "@tiptap/extension-subscript": "^2.10.0",
    "@tiptap/extension-superscript": "^2.10.0",
    "@tiptap/extension-table": "^2.10.0",
    "@tiptap/extension-table-cell": "^2.10.0",
    "@tiptap/extension-table-header": "^2.10.0",
    "@tiptap/extension-table-row": "^2.10.0",
    "@tiptap/extension-task-item": "^2.10.0",
    "@tiptap/extension-task-list": "^2.10.0",
    "@tiptap/extension-text-align": "^2.10.0",
    "@tiptap/extension-text-style": "^2.10.0",
    "@tiptap/extension-underline": "^2.10.0",
    "@tiptap/starter-kit": "^2.10.0"
  },
  "optionalDependencies": {
    "katex": "^0.16.0",
    "mammoth": "^1.8.0"
  },
  "devDependencies": {
    "@tiptap/core": "^2.10.0",
    "@tiptap/pm": "^2.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/estin110/tiptap-editor.git"
  }
}
